# Copy this file to .env.local (which is git-ignored) and fill in real values.

# Required for Phase 2's map to render. Get one from Google Cloud Console >
# APIs & Services > Credentials, with the "Maps JavaScript API" enabled.
VITE_GOOGLE_MAPS_API_KEY=

# Optional. Leave blank to use Google's public DEMO_MAP_ID (fine for local
# dev). Create a real Map ID in Cloud Console > Google Maps Platform > Map
# Management if you want custom map styling.
VITE_GOOGLE_MAPS_MAP_ID=

# Leave blank to keep using the local mock API (src/mocks). Set this once
# the FastAPI backend has a real URL, e.g. https://api.citizenpriority.gov
VITE_API_BASE_URL=
