# ── Google AI Studio (free) ──────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/app/apikey  (no payment needed)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — gemini-1.5-flash is free tier, fast, multimodal
GEMINI_MODEL=gemini-1.5-flash

# ── Firebase (Spark free plan) ────────────────────────────────────────────────
# Create a project at: https://console.firebase.google.com
# Project Settings → Service Accounts → Generate new private key → download JSON
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── App config ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Confidence thresholds (0.0 - 1.0)
# Below LOW  → "low_confidence" flag, warn UI to prompt user to clarify
# Below HIGH → "medium_confidence", AI label shown with override option
CONFIDENCE_THRESHOLD_LOW=0.50
CONFIDENCE_THRESHOLD_HIGH=0.80

# Max file sizes
MAX_AUDIO_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5
